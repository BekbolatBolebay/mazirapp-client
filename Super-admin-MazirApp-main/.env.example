# ===========================
# Frontend Environment Variables
# These variables are exposed to the browser (VITE_ prefix)
# ===========================

# API Configuration
VITE_API_URL=http://localhost:5000/api

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Gemini API (for AI features)
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# App Configuration
VITE_APP_ENV=development
VITE_APP_NAME=Cafe SaaS Admin

# ===========================
# Backend Environment Variables
# These are server-only and NOT exposed to the browser
# ===========================

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/cafe_saas

# Supabase Admin Secret
SUPABASE_ADMIN_KEY=your-admin-key-here

# Server Configuration
SERVER_PORT=5000
SERVER_HOST=localhost

# Gemini API Key (backend)
GEMINI_API_KEY=your-gemini-api-key-here

# Node Environment
NODE_ENV=development
