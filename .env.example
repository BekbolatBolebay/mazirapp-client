# --- General Config ---
POSTGRES_PASSWORD=your_secure_password
JWT_SECRET=your_jwt_secret
ANON_KEY=your_anon_key
SERVICE_ROLE_KEY=your_service_role_key

# --- Domain Config ---
CLIENT_URL=https://mazirapp.kz
ADMIN_URL=https://admin.mazirapp.kz

# --- Next.js Build Time Vars ---
# Any NEXT_PUBLIC_ vars needed at build time should be here or in Dockerfile
NEXT_PUBLIC_SUPABASE_URL=https://mazirapp.kz/rest/v1
NEXT_PUBLIC_SUPABASE_ANON_KEY=${ANON_KEY}

# --- Storage (MinIO) ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=secure_minio_password
MINIO_BUCKET=mazir-assets
